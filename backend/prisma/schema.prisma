// =============================================================================
// schema.prisma
//
// Prisma schema for the eGov municipal service desk application of
// Aluguinsan, Cebu. Defines the MySQL database structure covering citizens
// (Users), government staff (Servants), municipal departments, support
// tickets, messaging, file attachments, notifications, resident feedback,
// public announcements, and the public-directory of officials/services.
//
// Database: MySQL (connection URL read from the DATABASE_URL environment var)
// ORM:      Prisma Client JS
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// User
//
// Represents a registered resident (citizen) or system administrator.
// Residents submit and track support tickets; admins have elevated access
// for managing the platform.  Either an email or a phone number is required
// for authentication, but both are optional to allow flexible sign-up flows.
// -----------------------------------------------------------------------------
model User {
  // Unique collision-resistant identifier generated by Prisma (CUID)
  id          String    @id @default(cuid())

  // Contact / authentication fields — at least one must be provided
  email       String?   @unique  // Optional email address; unique across all users
  phone       String?   @unique  // Optional mobile number; unique across all users

  // Profile information
  name        String             // Full display name of the resident
  barangay    String             // Barangay (village) the resident belongs to
  address     String?            // Optional full street / house address

  // Access control
  role        Role      @default(CLIENT)   // CLIENT for residents, ADMIN for administrators
  password    String?                      // Bcrypt-hashed password (null if using OTP/social login)
  isVerified  Boolean   @default(false)    // True once the account has been verified (email / phone OTP)

  // Preferences
  language    Language  @default(ENGLISH)  // Preferred language for notifications and UI

  // Display
  avatarUrl   String?   // URL to the user's profile picture (optional)

  // Verification
  idPhotoUrl  String?   // URL to the citizen's uploaded valid ID photo

  // Timestamps
  createdAt   DateTime  @default(now())  // When the account was created
  updatedAt   DateTime  @updatedAt       // Automatically updated on every write

  // Relations
  tickets              Ticket[]        // Tickets submitted by this user
  notifications        Notification[]  // In-app notifications sent to this user
  createdAnnouncements Announcement[]  // Announcements authored by this user (admins)

  @@map("users")
}

// -----------------------------------------------------------------------------
// Servant
//
// Represents a municipal government employee who handles and resolves
// resident tickets.  Each servant belongs to exactly one Department and
// carries a real-time workload counter so the assignment engine can route
// new tickets to the least-busy available staff member.
// -----------------------------------------------------------------------------
model Servant {
  // Unique collision-resistant identifier
  id           String        @id @default(cuid())

  // Authentication & identity
  email        String        @unique  // Official government email address
  name         String                 // Full name of the employee
  position     String                 // Job title (e.g. "Engineer I")
  phone        String?                // Optional direct phone line
  password     String                 // Bcrypt-hashed login password

  // Department assignment — every servant belongs to one department
  departmentId String
  department   Department    @relation(fields: [departmentId], references: [id])

  // Availability tracking
  status       ServantStatus @default(AVAILABLE)  // Current availability: AVAILABLE, BUSY, or OFFLINE
  workload     Int           @default(0)           // Number of open tickets currently assigned to this servant

  // Display
  avatarUrl    String?    // URL to the servant's profile picture (optional)

  // Activity tracking
  lastActiveAt DateTime?  // Timestamp of the servant's most recent activity (null if never logged in)

  // Timestamps
  createdAt    DateTime      @default(now())  // When the servant account was created
  updatedAt    DateTime      @updatedAt       // Automatically updated on every write

  // Relations
  tickets  Ticket[]        // Tickets currently or previously assigned to this servant
  messages TicketMessage[] // Messages sent by this servant within ticket conversations

  @@index([departmentId])  // Speed up queries filtering servants by department
  @@index([status])        // Speed up availability lookups during ticket assignment
  @@map("servants")
}

// -----------------------------------------------------------------------------
// Department
//
// Represents a municipal government office or agency (e.g. Mayor's Office,
// Rural Health Unit).  Departments own a pool of Servants and receive Tickets
// that are routed to them based on AI keyword matching against their
// `keywords` list.
// -----------------------------------------------------------------------------
model Department {
  // Unique collision-resistant identifier
  id          String   @id @default(cuid())

  // Identity
  name        String           // Human-readable office name (e.g. "Municipal Engineering Office")
  code        String   @unique // Short unique code used as a stable reference key (e.g. "ENGINEERING")
  description String?  @db.Text // Brief description of the department's services and responsibilities
  head        String?           // Name / title of the department head or officer-in-charge

  // Contact information
  email       String?  // Official department email address
  phone       String?  // Official department phone number

  // AI-assisted ticket routing
  keywords    Json     @default("[]")  // JSON array of keywords used by the AI classifier to route tickets here

  // UI / branding
  color       String   @default("#3B82F6")  // Hex colour used to identify this department in the UI
  icon        String   @default("building") // Icon name (Lucide icon set) displayed alongside the department

  // Soft-delete / visibility
  isActive    Boolean  @default(true)  // When false, the department is hidden and stops receiving new tickets

  // Timestamps
  createdAt   DateTime @default(now())  // When the department record was created
  updatedAt   DateTime @updatedAt       // Automatically updated on every write

  // Relations
  servants Servant[]  // Staff members belonging to this department
  tickets  Ticket[]   // Tickets that have been routed to this department

  @@map("departments")
}

// -----------------------------------------------------------------------------
// Ticket
//
// The core entity of the system.  A Ticket represents a service request,
// complaint, or inquiry submitted by a resident.  It is routed to a
// Department (optionally to a specific Servant), tracked through a lifecycle
// of statuses, and may carry SLA deadlines, GPS coordinates, and escalation
// metadata.
// -----------------------------------------------------------------------------
model Ticket {
  // Unique collision-resistant identifier
  id               String       @id @default(cuid())

  // Human-readable reference shown to residents (e.g. "TKT-20240315-0001")
  ticketNumber     String       @unique

  // Ownership — the resident who filed the ticket
  userId           String
  user             User         @relation(fields: [userId], references: [id])

  // Routing — the department responsible for resolving this ticket
  departmentId     String
  department       Department   @relation(fields: [departmentId], references: [id])

  // Assignment — the specific servant handling this ticket (null until assigned)
  servantId        String?
  servant          Servant?     @relation(fields: [servantId], references: [id])

  // Ticket content
  title            String        // Short summary / subject line entered by the resident
  description      String       @db.Text  // Full narrative of the request or complaint
  category         String        // Freeform category label (e.g. "Road Repair", "Health Certificate")

  // Lifecycle state
  status           TicketStatus @default(PENDING)  // Current workflow status of the ticket
  priority         Priority     @default(NORMAL)   // Urgency level: LOW, NORMAL, or URGENT

  // AI classification metadata
  aiConfidence     Float?  // Confidence score (0–1) returned by the AI routing classifier

  // Optional location data submitted by the resident
  latitude         Float?   // GPS latitude of the reported issue location
  longitude        Float?   // GPS longitude of the reported issue location

  // SLA & escalation tracking
  slaDeadline      DateTime?    // Deadline by which the ticket must be resolved (per SLA policy)
  escalatedAt      DateTime?    // Timestamp when the ticket was escalated
  escalationReason String?      @db.Text  // Explanation recorded when the ticket was escalated

  // Resolution
  resolvedAt       DateTime?  // Timestamp when the ticket was marked as resolved

  // Timestamps
  createdAt        DateTime     @default(now())  // When the ticket was submitted
  updatedAt        DateTime     @updatedAt       // Automatically updated on every write

  // Relations
  attachments   Attachment[]    // Files uploaded by the resident or servant
  messages      TicketMessage[] // Conversation thread between resident and servant
  feedback      Feedback?       // Post-resolution satisfaction rating from the resident
  notifications Notification[]  // Notifications triggered by state changes on this ticket

  @@index([userId])        // Resident inbox queries
  @@index([servantId])     // Servant workload queries
  @@index([departmentId])  // Department queue queries
  @@index([status])        // Status-based filtering (e.g. all PENDING tickets)
  @@index([priority])      // Priority-based filtering (e.g. all URGENT tickets)
  @@index([slaDeadline])   // SLA breach detection queries
  @@map("tickets")
}

// -----------------------------------------------------------------------------
// Attachment
//
// A file uploaded in support of a Ticket (e.g. photos of road damage,
// scanned documents).  Deleted automatically when the parent Ticket is
// deleted (Cascade).
// -----------------------------------------------------------------------------
model Attachment {
  // Unique collision-resistant identifier
  id        String   @id @default(cuid())

  // Parent ticket reference
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  // File metadata stored at upload time
  fileName  String  // Original filename as supplied by the uploader
  filePath  String  // Server-side storage path or cloud URL where the file is saved
  fileSize  Int     // File size in bytes
  mimeType  String  // MIME type (e.g. "image/jpeg", "application/pdf")

  // Timestamp
  createdAt DateTime @default(now())  // When the attachment was uploaded

  @@index([ticketId])  // Fast retrieval of all attachments for a given ticket
  @@map("attachments")
}

// -----------------------------------------------------------------------------
// TicketMessage
//
// A single message in the conversation thread attached to a Ticket.
// Messages can be sent by the resident (CLIENT), a servant (SERVANT), or
// generated automatically by the system (SYSTEM).  Internal messages are
// only visible to servants and admins, not to the resident.
// -----------------------------------------------------------------------------
model TicketMessage {
  // Unique collision-resistant identifier
  id         String     @id @default(cuid())

  // Parent ticket — message is deleted with its ticket (Cascade)
  ticketId   String
  ticket     Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  // Sender identification
  servantId  String?    // Populated only when the sender is a Servant (null for CLIENT / SYSTEM)
  servant    Servant?   @relation(fields: [servantId], references: [id])
  senderType SenderType // Discriminator: CLIENT, SERVANT, or SYSTEM
  senderName String     // Display name of the sender at the time of writing

  // Content
  message    String     @db.Text  // The full message body (supports long text)
  attachments String?   @db.Text  // JSON array of file objects: [{ fileName, filePath, fileSize, mimeType }]

  // Visibility
  isInternal Boolean    @default(false)  // When true, the message is a private staff note hidden from the resident

  // Timestamp
  createdAt  DateTime   @default(now())  // When the message was posted

  @@index([ticketId])              // All messages for a ticket
  @@index([ticketId, isInternal])  // Resident-visible messages vs. internal notes
  @@map("ticket_messages")
}

// -----------------------------------------------------------------------------
// Notification
//
// An in-app notification delivered to a User (resident) when a significant
// event occurs on one of their Tickets (e.g. ticket assigned, status changed,
// new message received).  The `type` field carries a string code understood
// by the frontend to render the appropriate icon / copy.
// -----------------------------------------------------------------------------
model Notification {
  // Unique collision-resistant identifier
  id        String   @id @default(cuid())

  // Recipient — the resident who receives this notification
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Optional link back to the ticket that triggered this notification
  ticketId  String?
  ticket    Ticket?  @relation(fields: [ticketId], references: [id])

  // Notification content
  type      String   // Event type code (e.g. "TICKET_ASSIGNED", "STATUS_CHANGED")
  title     String   // Short headline shown in the notification list
  message   String   @db.Text  // Longer body text with contextual details

  // State
  isRead    Boolean  @default(false)  // Flipped to true when the user opens / acknowledges the notification

  // Timestamp
  createdAt DateTime @default(now())  // When the notification was created

  @@index([userId])          // All notifications for a given user
  @@index([userId, isRead])  // Unread-count badge queries
  @@map("notifications")
}

// -----------------------------------------------------------------------------
// Feedback
//
// A post-resolution satisfaction survey response left by the resident after
// their Ticket is closed.  One Feedback record per Ticket (enforced by
// @unique on ticketId).  The `rating` is typically a 1–5 integer star score.
// -----------------------------------------------------------------------------
model Feedback {
  // Unique collision-resistant identifier
  id        String   @id @default(cuid())

  // One-to-one link to the resolved ticket
  ticketId  String   @unique  // Ensures only one feedback entry per ticket
  ticket    Ticket   @relation(fields: [ticketId], references: [id])

  // Survey response
  rating    Int      // Satisfaction score (e.g. 1 = very dissatisfied, 5 = very satisfied)
  comment   String?  @db.Text  // Optional free-text comment from the resident

  // Timestamps
  createdAt DateTime @default(now())  // When the feedback was submitted
  updatedAt DateTime @updatedAt       // Automatically updated on every write

  @@map("feedbacks")
}

// -----------------------------------------------------------------------------
// Announcement
//
// A public notice or bulletin posted by an admin or authorized user and
// displayed to all residents on the platform (news feed, dashboard banner).
// Announcements can be categorised as informational (INFO), urgent alerts
// (ALERT), or community events (EVENT).
// -----------------------------------------------------------------------------
model Announcement {
  // Unique collision-resistant identifier
  id          String               @id @default(cuid())

  // Content
  title       String               // Headline of the announcement
  content     String               @db.LongText          // Full body — supports long HTML/markdown content
  category    AnnouncementCategory @default(INFO)         // INFO, ALERT, or EVENT

  // Publishing control
  isPublished Boolean              @default(true)    // When false, the announcement is a draft not visible to residents
  publishedAt DateTime?            // Explicit publish date/time (null = published immediately on creation)

  // Authorship — nullable to support system-generated announcements
  createdById String?
  createdBy   User?                @relation(fields: [createdById], references: [id])

  // Timestamps
  createdAt   DateTime             @default(now())  // When the announcement record was created
  updatedAt   DateTime             @updatedAt       // Automatically updated on every write

  @@index([isPublished])  // Efficiently fetch all currently published announcements
  @@index([category])     // Filter announcements by category
  @@map("announcements")
}

// -----------------------------------------------------------------------------
// DirectoryEntry
//
// A public contact record in the municipal directory.  Entries can represent
// elected officials (OFFICIAL), emergency services (EMERGENCY), or general
// public services (SERVICE), giving residents a single place to look up
// contact details for the local government.
// -----------------------------------------------------------------------------
model DirectoryEntry {
  // Unique collision-resistant identifier
  id          String            @id @default(cuid())

  // Contact / identity information
  name        String             // Full name of the official or service
  position    String             // Job title or role description
  department  String?            // Name of the department or agency (freeform, not a FK)
  address     String?            // Physical office address
  phone       String?            // Contact phone number
  email       String?            // Contact email address
  officeHours String?            // Stated office hours (e.g. "Mon–Fri 8AM–5PM")

  // Classification
  category    DirectoryCategory @default(OFFICIAL)  // OFFICIAL, EMERGENCY, or SERVICE

  // Visibility
  isActive    Boolean           @default(true)  // When false, the entry is hidden from the public directory

  // Timestamps
  createdAt   DateTime          @default(now())  // When the directory entry was added
  updatedAt   DateTime          @updatedAt       // Automatically updated on every write

  @@index([category])  // Filter directory by category (e.g. show only emergency contacts)
  @@index([isActive])  // Quickly fetch only active entries
  @@map("directory_entries")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

// User roles — determines access level within the application
enum Role {
  CLIENT  // Regular resident; can submit and view their own tickets
  ADMIN   // System administrator; full platform access
}

// Ticket lifecycle states — progress of a service request from submission to closure
enum TicketStatus {
  PENDING      // Ticket submitted but not yet reviewed or assigned
  ASSIGNED     // Ticket has been assigned to a servant but work has not started
  IN_PROGRESS  // Servant is actively working on the ticket
  RESOLVED     // Issue has been addressed; awaiting resident confirmation or auto-closure
  CLOSED       // Ticket is fully closed (no further action)
  ESCALATED    // Ticket has been escalated due to SLA breach or unresolved complexity
}

// Ticket urgency levels — influences SLA deadlines and queue ordering
enum Priority {
  LOW     // Non-urgent request with a relaxed SLA
  NORMAL  // Standard request processed in the default SLA window
  URGENT  // Time-sensitive issue requiring immediate attention
}

// UI / notification language preference for residents
enum Language {
  ENGLISH   // English
  FILIPINO  // Filipino (Tagalog-based national language)
  CEBUANO   // Cebuano (primary local dialect of Cebu)
}

// Real-time availability status of a government servant
enum ServantStatus {
  AVAILABLE  // Servant is online and accepting new ticket assignments
  BUSY       // Servant has reached their workload capacity
  OFFLINE    // Servant is not currently active on the platform
}

// Identifies who sent a message within a ticket conversation thread
enum SenderType {
  CLIENT   // Message sent by the resident who owns the ticket
  SERVANT  // Message sent by an assigned government servant
  SYSTEM   // Automated message generated by the platform (e.g. status-change notice)
}

// Category of a public announcement
enum AnnouncementCategory {
  INFO   // General informational notice (e.g. office hours, new services)
  ALERT  // Urgent public safety or emergency advisory
  EVENT  // Community event, activity, or programme invitation
}

// Category of a public directory entry
enum DirectoryCategory {
  OFFICIAL   // Elected or appointed government official
  EMERGENCY  // Emergency services contact (e.g. fire, police, disaster response)
  SERVICE    // General public service or utility (e.g. water, power, health)
}
