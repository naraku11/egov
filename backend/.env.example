# =============================================================================
# E-Government Assistance System — Municipality of Aluguinsan, Cebu
# Backend Environment Configuration (Example)
# =============================================================================

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=u856082912_egovdb
DB_USER=u856082912_egov
DB_PASS=your_database_password
DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3306/DATABASE_NAME

# ─── Cache ────────────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=supersecret_change_this_in_production_minimum_32_chars
JWT_EXPIRES_IN=7d

# ─── AI (Anthropic) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
CLIENT_URL=https://aluguinsan-egov.online

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ─── SMTP (Hostinger Email) ───────────────────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@aluguinsan-egov.online
SMTP_PASS=your_email_password
EMAIL_FROM=info@aluguinsan-egov.online
