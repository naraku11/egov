# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/
ai-classifier/__pycache__/
ai-classifier/*.pyc
ai-classifier/venv/

# Build output (commit only when deploying without a build step on server)
# frontend/dist/

# Environment files — NEVER commit real secrets
.env
backend/.env
frontend/.env
*.env.local

# Firebase service account key — NEVER commit
firebase-service-account.json
backend/firebase-service-account.json

# Prisma — migration_lock.toml MUST be committed so `prisma migrate deploy` works
# backend/prisma/migrations/migration_lock.toml

# Uploads (user-submitted files)
backend/uploads/*
!backend/uploads/.gitkeep

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Docker volumes
postgres-data/
redis-data/
