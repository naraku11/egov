# =============================================================================
# E-Government Assistance System — Municipality of Aloguinsan, Cebu
# Root Environment Configuration (Hostinger Deployment)
# =============================================================================
# Copy this file to backend/.env and fill in real credentials.

# ─── Database ────────────────────────────────────────────────────────────────
# Hostinger MySQL — use credentials from hPanel → Databases
DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3306/DATABASE_NAME

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=supersecret_change_this_in_production_minimum_32_chars
JWT_EXPIRES_IN=7d

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
CLIENT_URL=https://aloguinsan-egov.online

# ─── SMTP (Hostinger Email) ───────────────────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@aloguinsan-egov.online
SMTP_PASS=your_email_password
EMAIL_FROM=info@aloguinsan-egov.online

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ─── AI Classifier ───────────────────────────────────────────────────────────
# Leave empty to use the built-in keyword classifier instead of Claude AI
ANTHROPIC_API_KEY=
