# ─── Database ────────────────────────────────────────────────────────────────
# Local Docker: mysql://egov:egov_secret@localhost:3306/egov_aluguinsan
# Hostinger:    use the MySQL credentials from hPanel → Databases
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE_NAME

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=supersecret_change_this_in_production_minimum_32_chars
JWT_EXPIRES_IN=7d

# ─── App ─────────────────────────────────────────────────────────────────────
# Local development:  NODE_ENV=development, PORT=5000, CLIENT_URL=http://localhost:3000
# Hostinger:          NODE_ENV=production,  PORT set by Hostinger automatically
NODE_ENV=production
PORT=5000
# Set CLIENT_URL to your Hostinger domain (used for CORS)
# In production the frontend is served by the same Express server, so same-origin
# requests don't need CORS — but set this to your domain for cross-origin API clients.
CLIENT_URL=https://yourdomain.com

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
# Hostinger Business includes email hosting — use SMTP credentials from hPanel
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_email_password
EMAIL_FROM=noreply@yourdomain.com

# ─── File Storage ────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ─── AI Classifier ────────────────────────────────────────────────────────────
# Uses Claude Haiku (fast + cheap). Leave empty to use the built-in keyword classifier.
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Redis (optional — remove if not using caching) ─────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── SMS / Twilio (optional) ─────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890
